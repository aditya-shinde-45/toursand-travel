# Database Configuration
DATABASE_URL=postgresql://postgres:your-db-password@your-supabase-host:5432/postgres

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret
JWT_SECRET=replace-with-a-strong-random-secret

# Admin Login Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_EMAIL=admin@example.com

# CORS Origin
CORS_ORIGIN=http://localhost:5173

# Trust proxy (set true if running behind Nginx/Cloudflare/Load balancer)
TRUST_PROXY=false

# Rate limiting (all values are per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_MAX=10
TRACK_RATE_LIMIT_MAX=30
CONTACT_RATE_LIMIT_MAX=10

# Email Configuration (Use Gmail App Password, not normal Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info.adityatourstravels@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Aditya Tours & Travels <info.adityatourstravels@gmail.com>"
